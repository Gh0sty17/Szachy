<Window x:Class="Szachy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Szachy"
        mc:Ignorable="d"
        Title="Szachy WPF - 2 Graczy" Height="650" Width="600"
        WindowStartupLocation="CenterScreen" Background="#2F2F2F">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        
        <TextBlock x:Name="StatusText" Grid.Row="0" Text="Ruch: Białe" 
                   HorizontalAlignment="Center" FontSize="20" FontWeight="Bold" 
                   Foreground="White" Margin="0,0,0,10"/>

        
        <UniformGrid x:Name="ChessBoardGrid" Grid.Row="1" Rows="8" Columns="8" 
                     Background="#404040" Cursor="Hand"/>
    </Grid>
</Window>
